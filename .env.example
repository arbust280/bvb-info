# Copy to .env and adjust. All variables are optional; sensible defaults apply.

# Database — default is local SQLite (zero setup). For PostgreSQL:
# BVB_DATABASE_URL=postgresql+psycopg2://bvb:bvb@localhost:5432/bvb
BVB_DATABASE_URL=sqlite:///bvb.sqlite3

# Read-only connection for the public API (falls back to BVB_DATABASE_URL)
# BVB_API_DATABASE_URL=postgresql+psycopg2://readonly_user:pass@host/db

# HTTP tuning
BVB_MAX_WORKERS=6
BVB_REQUEST_DELAY=0.35
BVB_REQUEST_TIMEOUT=20
BVB_RETRY_TOTAL=5
BVB_RETRY_BACKOFF=0.5

# Storage + logging
BVB_STORAGE_DIR=storage
BVB_LOG_LEVEL=INFO
